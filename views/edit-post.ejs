<%
  layout = false;
  const isLoggedIn = typeof user !== 'undefined' && user;
%>
<%# Primary function: render the page for editing a history board post. %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit History Board - The History Board</title>
  <link href="/styles.css" rel="stylesheet">
</head>
<body class="create-post">

  <%# Navigation bar for the edit page, visible only when logged in. %>
  <nav>
    <div class="nav-brand">The History Board</div>
    <% if (isLoggedIn) { %>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/create-post" class="btn">+ New History Board</a>
        <div class="nav-user">
          Welcome, <strong><%= username %></strong>
          <a href="/logout">Logout</a>
        </div>
      </div>
    <% } %>
  </nav>

  <div class="container">
    <%# Page content area containing the edit form. %>
    <div class="card">
      <h1>Edit History Board</h1>

      <% if (typeof error !== 'undefined') { %>
        <%# Display an error if updating the post failed. %>
        <div class="alert"><%= error %></div>
      <% } %>

      <%# Form to update the chosen post title and content. %>
      <form method="POST" action="/edit-post/<%= post.id %>">
        <div class="form-group">
          <label for="title">Board Title</label>
          <input type="text" id="title" name="title" required value="<%= post.title %>" placeholder="What historical event or figure shall we explore?">
        </div>

        <div class="form-group">
          <label for="content">Historical Content</label>
          <textarea id="content" name="content" required placeholder="Share your insights, facts, and perspectives on this piece of history..."><%= post.content %></textarea>
        </div>

        <div class="button-group">
          <button type="submit" class="btn">Update History Board</button>
          <a href="/post/<%= post.id %>" class="btn btn-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>