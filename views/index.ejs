<%
  layout = false;
  const isLoggedIn = typeof user !== 'undefined' && user;
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home - The History Board</title>
  <link href="/styles.css" rel="stylesheet">
</head>
<body>
  <nav>
    <div class="nav-brand">The History Board</div>
    <% if (isLoggedIn) { %>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/create-post" class="btn">+ New Board</a>
        <div class="nav-user">
          Welcome, <strong><%= username %></strong>
          <a href="/logout">Logout</a>
        </div>
      </div>
    <% } else { %>
      <div class="nav-links">
        <a href="/login">Login</a>
        <a href="/signup">Sign Up</a>
      </div>
    <% } %>
  </nav>

  <div class="container">
    <h1>All Boards</h1>

    <% if (posts && posts.length > 0) { %>
      <% posts.forEach(post => { %>
        <div class="card" onclick="window.location.href='/post/<%= post.id %>'">
          <div class="post-title"><%= post.title %></div>
          <div class="post-meta">
            by <strong><%= post.username %></strong>
            on <%= new Date(post.created_at).toLocaleDateString() %>
          </div>
          <div class="post-content"><%= post.content %></div>
          <a href="/post/<%= post.id %>" class="post-card-link">Read more →</a>
          
          <% if (isLoggedIn && user === post.user_id) { %>
            <div class="post-actions">
              <form method="POST" action="/delete-post/<%= post.id %>" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this board?');">
                <button type="submit" class="btn btn-danger">Delete</button>
              </form>
            </div>
          <% } %>
        </div>
      <% }); %>
    <% } else { %>
      <div class="empty-state">
        <p>No boards yet. Be the first to create one!</p>
        <% if (isLoggedIn) { %>
          <a href="/create-post" class="btn">Create Your First Board</a>
        <% } else { %>
          <a href="/signup" class="btn">Sign Up to Create Boards</a>
        <% } %>
      </div>
    <% } %>
  </div>
</body>
</html>
