<% layout = false %>
<%# Primary function: render the login page for returning users. %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - The History Board</title>
  <link href="/styles.css" rel="stylesheet">
</head>
<body class="auth-page">

  <div class="container">
    <%# Main login box for existing users. %>
    <h1>Login</h1>
    
    <% if (typeof error !== 'undefined') { %>
      <%# Show login errors when authentication fails. %>
      <div class="alert"><%= error %></div>
    <% } %>

    <%# Login form sends credentials to the login route. %>
    <form method="POST" action="/login">
      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" required>
      </div>

      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required>
      </div>

      <button type="submit" class="btn">Login</button>
    </form>

    <%# Prompt visitors to sign up if they don't yet have an account. %>
    <div class="auth-link">
      Don't have an account? <a href="/signup">Sign up here</a>
    </div>
  </div>
</body>
</html>
